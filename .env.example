# ============================================
# SkinLab Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env
# ============================================

# --- Supabase (Frontend) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase Project ID (used internally) ---
VITE_SUPABASE_PROJECT_ID=

# --- Razorpay (Frontend - Publishable Key) ---
# Get from: https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=

# ============================================
# Edge Function Secrets (set in Supabase Dashboard → Settings → Edge Functions → Secrets)
# These are NOT prefixed with VITE_ as they are server-side only
# ============================================

# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# --- WhatsApp Business API (for order notifications) ---
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# --- Supabase Service Role (server-only secret) ---
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
